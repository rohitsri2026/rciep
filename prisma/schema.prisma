generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  STUDENT
}

enum QuestionType {
  MCQ
  TRUE_FALSE
  NUMERICAL
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum QuestionStatus {
  DRAFT
  APPROVED
  DISABLED
}

enum AttemptStatus {
  IN_PROGRESS
  COMPLETED
}

model User {
  id        String    @id @default(cuid())
  name      String?
  email     String    @unique
  password  String    // Hashed password
  role      Role      @default(STUDENT)
  image     String?
  attempts  Attempt[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Subject {
  id          String     @id @default(cuid())
  name        String     // Removed @unique to allow active-only uniqueness validation
  description String?
  status      String     @default("ACTIVE") // "ACTIVE" | "INACTIVE"
  icon        String?    // Optional icon identifier
  color       String?    // Optional color theme
  isDeleted   Boolean    @default(false)
  deletedAt   DateTime?
  categories  Category[]
  questions   Question[]
  tests       Test[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Category {
  id           String     @id @default(cuid())
  name         String
  description  String?
  status       String     @default("ACTIVE") // "ACTIVE" | "INACTIVE"
  displayOrder Int        @default(0)
  isDeleted    Boolean    @default(false)
  deletedAt    DateTime?
  subjectId    String
  subject      Subject    @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  questions    Question[]
  tests        Test[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([subjectId])
}

model Question {
  id            String         @id @default(cuid())
  text          String
  type          QuestionType   @default(MCQ)
  options       Json?          // MCQ: { "A": "Option text", "B": "...", "C": "...", "D": "..." }
  correctAnswer String         // MCQ: "A" | "B" | "C" | "D", True/False: "true" | "false", Numerical: direct string
  explanation   String?
  points        Int            @default(1)
  difficulty    Difficulty     @default(MEDIUM)
  status        QuestionStatus @default(DRAFT)
  questionImage String?        // Question image attachment URL
  optionImages  Json?          // Option image attachment URLs map e.g., { "A": "URL", "B": null, ... }
  
  subjectId     String
  subject       Subject        @relation(fields: [subjectId], references: [id])
  categoryId    String?
  category      Category?      @relation(fields: [categoryId], references: [id])
  
  tests         TestQuestion[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([subjectId])
  @@index([categoryId])
}

model Test {
  id                         String         @id @default(cuid())
  title                      String
  description                String?
  duration                   Int            // Duration in minutes
  totalMarks                 Int
  passMarks                  Int
  type                       String         @default("MOCK_TEST") // PRACTICE_QUIZ | MOCK_TEST | SECTIONAL_TEST | PREVIOUS_YEAR_PAPER | DAILY_QUIZ
  status                     String         @default("DRAFT")     // DRAFT | PUBLISHED | ARCHIVED
  visibility                 String         @default("PUBLIC")    // PUBLIC | PRIVATE
  negativeMarking            Float          @default(0.0)
  instructions               String?        @db.Text
  allowMultipleAttempts      Boolean        @default(true)
  allowResume                Boolean        @default(true)
  shuffleQuestions           Boolean        @default(false)
  shuffleOptions             Boolean        @default(false)
  showResultImmediately      Boolean        @default(true)
  showAnswersAfterSubmission Boolean        @default(true)
  startDate                  DateTime?
  endDate                    DateTime?
  isDeleted                  Boolean        @default(false)
  deletedAt                  DateTime?
  subjectId                  String
  subject                    Subject        @relation(fields: [subjectId], references: [id])
  categoryId                 String?
  category                   Category?      @relation(fields: [categoryId], references: [id])
  questions                  TestQuestion[]
  attempts                   Attempt[]
  createdAt                  DateTime       @default(now())
  updatedAt                  DateTime       @updatedAt

  @@index([subjectId])
  @@index([categoryId])
}

model TestQuestion {
  id           String   @id @default(cuid())
  testId       String
  test         Test     @relation(fields: [testId], references: [id], onDelete: Cascade)
  questionId   String
  question     Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  displayOrder Int      // Order within the exam
  marks        Int      @default(1) // Weight/marks of the question in this test
  negativeMark Float    @default(0.0) // Negative mark override
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([testId, questionId])
  @@index([questionId])
}

model Attempt {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  testId          String
  test            Test          @relation(fields: [testId], references: [id], onDelete: Cascade)
  score           Float?
  status          AttemptStatus @default(IN_PROGRESS)
  answers         Json?         // JSON map: { [questionId]: selectedAnswer }
  logs            Json?         // Cheating events
  correctCount    Int?
  wrongCount      Int?
  unansweredCount Int?
  timeTaken       Int?          // seconds
  isPassed        Boolean?
  startedAt       DateTime      @default(now())
  completedAt     DateTime?

  @@index([userId])
  @@index([testId])
}

